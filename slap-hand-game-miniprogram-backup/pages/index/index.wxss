.game-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx 28rpx 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  background:
    radial-gradient(circle at 50% 18%, rgba(255, 255, 255, 0.95), rgba(246, 247, 251, 0.2) 36%),
    linear-gradient(180deg, #f7fbff 0%, #edf2f7 100%);
}

.scorebar {
  width: 100%;
  max-width: 720rpx;
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.score-title {
  font-size: 34rpx;
  font-weight: 800;
  letter-spacing: 0;
  color: #111827;
}

.score-item {
  min-height: 82rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  background: rgba(17, 24, 39, 0.08);
  box-shadow: inset 0 0 0 2rpx rgba(17, 24, 39, 0.08);
}

.score-label {
  font-size: 24rpx;
  color: #4b5563;
}

.score-value {
  min-width: 40rpx;
  font-size: 36rpx;
  line-height: 1;
  font-weight: 900;
  color: #111827;
}

.arena {
  position: relative;
  width: 88vw;
  height: 88vw;
  max-width: 690rpx;
  max-height: 690rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: visible;
}

.face {
  width: 100%;
  height: 100%;
  filter: drop-shadow(0 18rpx 22rpx rgba(15, 23, 42, 0.18));
  transform-origin: 50% 58%;
}

.hand {
  position: absolute;
  z-index: 3;
  width: 54%;
  height: 54%;
  top: 28%;
  pointer-events: none;
  filter: drop-shadow(0 14rpx 16rpx rgba(15, 23, 42, 0.18));
}

.hand-from-left {
  left: -8%;
  animation: slapFromLeft 360ms cubic-bezier(0.14, 0.88, 0.22, 1) both;
}

.hand-from-right {
  right: -8%;
  animation: slapFromRight 360ms cubic-bezier(0.14, 0.88, 0.22, 1) both;
}

.impact {
  position: absolute;
  z-index: 4;
  top: 43%;
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  border: 8rpx solid rgba(255, 255, 255, 0.98);
  box-shadow:
    0 0 0 8rpx rgba(59, 130, 246, 0.16),
    0 0 38rpx rgba(245, 158, 11, 0.45);
  animation: impactPop 240ms ease-out both;
}

.impact-left {
  left: 22%;
}

.impact-right {
  right: 22%;
}

.shake-right .face {
  animation: faceShakeRight 420ms ease-out both;
}

.shake-left .face {
  animation: faceShakeLeft 420ms ease-out both;
}

.prompt {
  min-height: 52rpx;
  margin-top: 8rpx;
  margin-bottom: 20rpx;
  font-size: 26rpx;
  line-height: 52rpx;
  color: #374151;
  text-align: center;
}

.controls {
  width: 100%;
  max-width: 560rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 28rpx;
  margin-top: auto;
}

.key-button {
  height: 176rpx;
  padding: 0;
  border: 0;
  border-radius: 8rpx;
  background: transparent;
  box-shadow: none;
  overflow: visible;
}

.key-button::after {
  border: 0;
}

.key-button-active {
  transform: translateY(4rpx) scale(0.98);
  opacity: 0.88;
}

.key-icon {
  width: 100%;
  height: 100%;
  filter: drop-shadow(0 12rpx 16rpx rgba(15, 23, 42, 0.18));
}

@keyframes slapFromLeft {
  0% {
    opacity: 0;
    transform: translateX(-70%) translateY(8%) rotate(-18deg) scale(0.9);
  }
  42% {
    opacity: 1;
    transform: translateX(34%) translateY(-2%) rotate(9deg) scale(1.03);
  }
  100% {
    opacity: 0;
    transform: translateX(58%) translateY(-8%) rotate(16deg) scale(0.96);
  }
}

@keyframes slapFromRight {
  0% {
    opacity: 0;
    transform: translateX(70%) translateY(8%) rotate(18deg) scale(0.9);
  }
  42% {
    opacity: 1;
    transform: translateX(-34%) translateY(-2%) rotate(-9deg) scale(1.03);
  }
  100% {
    opacity: 0;
    transform: translateX(-58%) translateY(-8%) rotate(-16deg) scale(0.96);
  }
}

@keyframes faceShakeRight {
  0% { transform: translateX(0) rotate(0); }
  24% { transform: translateX(22rpx) rotate(4deg); }
  52% { transform: translateX(-8rpx) rotate(-1.5deg); }
  76% { transform: translateX(6rpx) rotate(1deg); }
  100% { transform: translateX(0) rotate(0); }
}

@keyframes faceShakeLeft {
  0% { transform: translateX(0) rotate(0); }
  24% { transform: translateX(-22rpx) rotate(-4deg); }
  52% { transform: translateX(8rpx) rotate(1.5deg); }
  76% { transform: translateX(-6rpx) rotate(-1deg); }
  100% { transform: translateX(0) rotate(0); }
}

@keyframes impactPop {
  0% {
    opacity: 0;
    transform: scale(0.3);
  }
  45% {
    opacity: 1;
    transform: scale(1.05);
  }
  100% {
    opacity: 0;
    transform: scale(1.6);
  }
}
